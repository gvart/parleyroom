# Hostname clients (browsers) use to reach this machine.
# On a LAN with mDNS this is usually "<hostname>.local" (e.g. rose.local).
APP_HOST=rose.local

# IPv4 of APP_HOST. LiveKit advertises this as its ICE candidate,
# so it must be routable from every device that will connect.
# Run ./scripts/setup-env.sh to auto-populate.
HOST_IP=127.0.0.1